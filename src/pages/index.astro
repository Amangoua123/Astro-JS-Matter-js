---
import Page from "../layout/Page.astro";
---

<Page>
  <section class="shapes"></section>
  <section class="difference"></section>
</Page>

<style>
  body {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 18px;
    line-height: 1.5;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-color: #fff;
    color: #333333;

    margin: 0;
    padding: 0;
  }

  .difference {
    position: fixed;
    top: 0;
    right: -50%;
    width: 100%;
    height: 100%;
    background-color: white;
    mix-blend-mode: difference;
    pointer-events: none;
  }
</style>
